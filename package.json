{
  "name": "club-crm",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @club/api --filter @club/web dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @club/api db:generate",
    "db:migrate": "pnpm --filter @club/api db:migrate",
    "db:seed": "pnpm --filter @club/api db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.7",
    "axe-core": "^4.10.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
